---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href="/" class="brand">
          <svg width="26" height="26" viewBox="0 0 30 30">
            <circle cx="15" cy="15" r="9" fill="none" stroke="#cbff3d" stroke-width="2"></circle>
            <g stroke="#cbff3d" stroke-width="2" stroke-linecap="round">
              <line x1="15" y1="0" x2="15" y2="4"></line><line x1="15" y1="26" x2="15" y2="30"></line>
              <line x1="0" y1="15" x2="4" y2="15"></line><line x1="26" y1="15" x2="30" y2="15"></line>
              <line x1="4.4" y1="4.4" x2="7.2" y2="7.2"></line><line x1="22.8" y1="22.8" x2="25.6" y2="25.6"></line>
              <line x1="4.4" y1="25.6" x2="7.2" y2="22.8"></line><line x1="22.8" y1="7.2" x2="25.6" y2="4.4"></line>
            </g>
          </svg>
          <span class="brand-name">CITRUS CONNECTIONS</span>
        </a>
        <p class="tagline">Digital marketing that earns attention and converts it — SEO, paid media, content and design under one roof.</p>
      </div>
      <div>
        <h6>Quick Links</h6>
        <div class="link-col">
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/services">Services</a>
          <a href="/blog">Blog</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
      <div>
        <h6>Contact</h6>
        <div class="link-col contact-col">
          <a href="mailto:hello@citrusconnections.com">hello@citrusconnections.com</a>
          <a href="tel:+18135550142">(813) 555-0142</a>
          <span>412 Harbor View Ave, Suite 220<br />Tampa, FL 33602</span>
        </div>
      </div>
      <div>
        <h6>Follow</h6>
        <div class="social-row">
          <a href="#" aria-label="Instagram" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="1"></circle></svg>
          </a>
          <a href="#" aria-label="LinkedIn" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4V9h4v1.5A5 5 0 0 1 16 8z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          </a>
          <a href="#" aria-label="X" class="social-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="4" x2="20" y2="20"></line><line x1="20" y1="4" x2="4" y2="20"></line></svg>
          </a>
          <a href="#" aria-label="Facebook" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {year} Citrus Connections. All rights reserved.</span>
      <span>Tampa, FL &middot; Serving clients nationwide</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg);
    border-top: 1px solid var(--border);
  }
  .site-footer .container {
    padding-top: 64px;
    padding-bottom: 32px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 48px;
    padding-bottom: 40px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #ffffff;
  }
  .brand-name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.03em;
  }
  .tagline {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 32ch;
    margin: 16px 0 0;
  }
  h6 {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 18px;
    font-weight: 600;
  }
  .link-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .link-col a {
    color: #fff;
    text-decoration: none;
    font-size: 14px;
  }
  .contact-col { color: rgba(255, 255, 255, 0.75); font-size: 14px; }
  .contact-col a { color: inherit; }
  .social-row { display: flex; gap: 10px; }
  .social-btn {
    width: 38px;
    height: 38px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .social-btn:hover { background: var(--accent); color: var(--bg); }
  .footer-bottom {
    border-top: 1px solid var(--border);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 13px;
    color: var(--text-faint);
  }
</style>
