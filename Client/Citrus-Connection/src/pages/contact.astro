---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Citrus Connections | Book a Free Strategy Call" description="Get in touch with Citrus Connections — a digital marketing agency in Tampa, FL. Book a free strategy call or send us a message about SEO, paid media or web design." active="contact">

  <section class="page-hero">
    <div class="container hero-inner">
      <span class="eyebrow">Contact</span>
      <h1>Let's talk about your next quarter of growth.</h1>
      <p class="lede">Tell us about your business and goals — we'll follow up within one business day to schedule your free strategy call.</p>
    </div>
  </section>

  <section class="contact-section">
    <div class="container contact-grid">

      <div id="thank-you" class="card thank-you-card" hidden>
        <span class="dot"></span>
        <h2>Message received.</h2>
        <p>Thanks, <span id="thank-you-name">there</span> — a strategist will reach out within one business day to schedule your free call. In the meantime, feel free to browse our <a href="/services">services</a> or <a href="/blog">blog</a>.</p>
      </div>

      <form id="contact-form" class="contact-form card">
        <div class="field">
          <label for="c-name">Name</label>
          <input id="c-name" name="name" required placeholder="Jamie Rivera" />
        </div>
        <div class="field-row">
          <div class="field">
            <label for="c-email">Email</label>
            <input id="c-email" name="email" type="email" required placeholder="jamie@company.com" />
          </div>
          <div class="field">
            <label for="c-phone">Phone</label>
            <input id="c-phone" name="phone" type="tel" placeholder="(555) 555-0123" />
          </div>
        </div>
        <div class="field">
          <label for="c-message">Message</label>
          <textarea id="c-message" name="message" rows="5" required placeholder="Tell us about your business and what you're looking to grow."></textarea>
        </div>
        <button type="submit" class="btn submit-btn">Send Message</button>
        <p class="disclaimer">By submitting, you agree to be contacted by Citrus Connections about your inquiry.</p>
      </form>

      <div class="contact-side">
        <div>
          <h3>Contact Info</h3>
          <div class="info-col">
            <a href="mailto:hello@citrusconnections.com">hello@citrusconnections.com</a>
            <a href="tel:+18135550142">(813) 555-0142</a>
            <span>412 Harbor View Ave, Suite 220<br />Tampa, FL 33602</span>
            <span class="hours">Mon&ndash;Fri, 9am&ndash;6pm ET</span>
          </div>
        </div>
        <div>
          <h3>Follow</h3>
          <div class="social-row">
            <a href="#" aria-label="Instagram" class="social-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="1"></circle></svg>
            </a>
            <a href="#" aria-label="LinkedIn" class="social-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4V9h4v1.5A5 5 0 0 1 16 8z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            </a>
            <a href="#" aria-label="X" class="social-btn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="4" x2="20" y2="20"></line><line x1="20" y1="4" x2="4" y2="20"></line></svg>
            </a>
            <a href="#" aria-label="Facebook" class="social-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <section class="map-section">
    <iframe title="Map showing Citrus Connections' Tampa, FL location" src="https://www.google.com/maps?q=Tampa,FL&output=embed" loading="lazy"></iframe>
  </section>

</Layout>

<style>
  .page-hero { padding: 88px clamp(20px, 5vw, 64px) 56px; }
  .hero-inner { max-width: 900px; margin: 0 auto; text-align: center; }
  .page-hero h1 { font-size: clamp(32px, 4.4vw, 52px); line-height: 1.18; margin: 0 0 24px; color: #fff; }
  .lede { font-size: 17px; line-height: 1.7; margin: 0 auto; max-width: 54ch; color: var(--text-muted); }

  .contact-section { padding: 16px clamp(20px, 5vw, 64px) 64px; }
  .contact-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 48px; align-items: start; }

  .thank-you-card { padding: 40px; }
  .thank-you-card .dot { width: 14px; height: 14px; background: var(--accent); border-radius: 999px; display: block; margin-bottom: 20px; }
  .thank-you-card h2 { font-size: 26px; color: #fff; margin: 0 0 16px; }
  .thank-you-card p { font-size: 15px; line-height: 1.7; color: var(--text-muted); margin: 0; max-width: 48ch; }

  .contact-form { padding: 40px; display: flex; flex-direction: column; gap: 20px; }
  .field label { display: block; font-size: 13px; color: var(--text-muted); margin-bottom: 8px; }
  .field-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
  input, textarea {
    width: 100%; box-sizing: border-box; background: var(--bg); border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 10px; padding: 13px 14px; color: #fff; font-size: 14px; font-family: var(--font-body);
  }
  input::placeholder, textarea::placeholder { color: rgba(255, 255, 255, 0.35); }
  textarea { resize: vertical; }
  .submit-btn { border: none; cursor: pointer; margin-top: 4px; width: fit-content; }
  .disclaimer { font-size: 12px; color: rgba(255, 255, 255, 0.4); margin: 0; }

  .contact-side { display: flex; flex-direction: column; gap: 32px; }
  .contact-side h3 { font-size: 17px; color: #fff; margin: 0 0 16px; }
  .info-col { display: flex; flex-direction: column; gap: 14px; font-size: 15px; }
  .info-col a { color: #fff; text-decoration: none; }
  .info-col span { color: var(--text-muted); }
  .hours { color: var(--text-faint) !important; font-size: 13.5px; }
  .social-row { display: flex; gap: 10px; }
  .social-btn {
    width: 38px; height: 38px; border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 999px;
    display: flex; align-items: center; justify-content: center; color: var(--accent); text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .social-btn:hover { background: var(--accent); color: var(--bg); }

  .map-section iframe { width: 100%; height: 420px; border: 0; display: block; filter: invert(0.92) contrast(0.9) hue-rotate(180deg); }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const thankYou = document.getElementById('thank-you') as HTMLElement | null;
  const thankYouName = document.getElementById('thank-you-name');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = (form.querySelector('#c-name') as HTMLInputElement)?.value.trim();
    if (thankYouName) thankYouName.textContent = name ? name.split(' ')[0] : 'there';
    form.hidden = true;
    if (thankYou) thankYou.hidden = false;
  });
</script>
